# --- OS / Editor Temporary Files ---
# Files left behind by text editors
*~
.*~
*.swp
*.orig

# Files created by file managers and system processes
.directory
.Trash-*
.fuse_hidden*
.nfs*

# --- Debian Live Build Specific Files ---
# These are generated by the `lb build` command and should not be tracked.
# The main ISO image
*.hybrid.iso

# The main build directory (usually named 'build/')
/build/

# The live-build configuration and cache directories
/config/chroot_local-packages
/config/chroot_local-includes
/config/includes.chroot_after_packages
/config/includes.chroot_before_packages
/config/includes.binary
/config/includes.installer
/cache/
.chroot
.bootstrap
.binary

# --- General Build Artifacts ---
# Binary and archive files
*.o
*.a
*.so
*.class
*.jar
*.zip
*.tar.gz
*.tgz

# Logs and databases
*.log
*.sqlite

# --- Temporary and Project-Specific Files ---
# If you use a local directory for testing
/live-build-tmp/
